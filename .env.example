# Andrii-IT NIS2 Audit Platform — Environment Variables
# Copy this file to .env and fill in your values. NEVER commit .env to git!

# Flask secret key — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_generate_with_python_secrets_token_hex_32

# Admin login
ADMIN_EMAIL=admin@andrii-it.de
ADMIN_PASSWORD=CHANGE_ME_use_strong_password_min_16_chars

# Anthropic API key for AI audit agent — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-...your-key-here...

# Database path (inside Docker volume)
DB_PATH=/data/nis2audit.db
